{
  "name": "@synkrypt/cli",
  "version": "2.0.0",
  "description": "Synkrypt CLI — Developer tools for secure secret management",
  "bin": {
    "synkrypt": "./index.ts"
  },
  "author": "Synkrypt Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhilaksh-arora/synkrypt.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/abhilaksh-arora/synkrypt/issues"
  },
  "homepage": "https://synkrypt.abhilaksharora.com/docs#cli-usage",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.ts",
    "src",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "module": "index.ts",
  "type": "module",
  "private": false,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "compile:linux-x64": "bun build ./index.ts --compile --minify --target=bun-linux-x64 --outfile ./bin/synkrypt-linux-x64",
    "compile:linux-arm64": "bun build ./index.ts --compile --minify --target=bun-linux-arm64 --outfile ./bin/synkrypt-linux-arm64",
    "compile:darwin-x64": "bun build ./index.ts --compile --minify --target=bun-darwin-x64 --outfile ./bin/synkrypt-macos-x64",
    "compile:darwin-arm64": "bun build ./index.ts --compile --minify --target=bun-darwin-arm64 --outfile ./bin/synkrypt-macos-arm64",
    "compile:windows-x64": "bun build ./index.ts --compile --minify --target=bun-windows-x64-baseline --outfile ./bin/synkrypt-windows-x64.exe",
    "compile:linux-x64:baseline": "bun build ./index.ts --compile --minify --target=bun-linux-x64-baseline --outfile ./bin/synkrypt-linux-x64",
    "compile:linux-arm64:baseline": "bun build ./index.ts --compile --minify --target=bun-linux-arm64-baseline --outfile ./bin/synkrypt-linux-arm64",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64 && bun run compile:windows-x64",
    "compile:all:baseline": "bun run compile:linux-x64:baseline && bun run compile:linux-arm64:baseline && bun run compile:darwin-x64 && bun run compile:darwin-arm64 && bun run compile:windows-x64",
    "release:assets": "bun run ./scripts/release-assets.ts",
    "publish": "bun run ./scripts/publish.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  }
}
