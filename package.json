{
  "name": "synkrypt-monorepo",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "cli",
    "server",
    "web"
  ],
  "scripts": {
    "dev": "turbo dev --filter=!@synkrypt/cli",
    "build": "turbo build",
    "install-all": "bun install",
    "cli": "bun run --filter \"@synkrypt/cli\" dev"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.9.6"
  }
}
