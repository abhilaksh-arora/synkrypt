# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/synkrypt

# Secure random 64-char hex strings
SERVER_SECRET=a1b2c3d4e5f6...
JWT_SECRET=f6e5d4c3b2a1...

# Allowed CORS origin (Production URL)
CORS_ORIGIN=https://vault.example.com

# Server port
PORT=2809

# Enable public registration for SaaS mode (true/false)
PUBLIC_REGISTRATION_ENABLED=false
